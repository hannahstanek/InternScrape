# ============================================================
# Job Scraper — Environment Variables
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ---- Database ----
DB_PATH=/Users/YOURNAME/Projects/job-scraper/data/jobs.db

# ---- Applicant Profiles ----
# Comma-separated paths to profile JSON files (one per applicant).
# Each file must conform to profile/applicant_profile.schema.json
APPLICANT_PROFILE_PATHS=/Users/YOURNAME/Projects/job-scraper/profile/applicant_01.json,/Users/YOURNAME/Projects/job-scraper/profile/applicant_02.json

# ---- Config Paths ----
TARGET_COMPANIES_PATH=/Users/YOURNAME/Projects/job-scraper/config/target_companies.json
ROLE_FILTERS_PATH=/Users/YOURNAME/Projects/job-scraper/config/role_filters.json
LOCATION_POLICY_PATH=/Users/YOURNAME/Projects/job-scraper/config/location_policy.json

# ---- n8n ----
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
# Webhook base URL used for approval deep links in alerts
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook

# ---- Alerting ----
# At least one channel must be configured.
ALERT_EMAIL_TO=you@email.com
ALERT_EMAIL_FROM=n8n-alerts@localhost
# Optional: Slack webhook URL
ALERT_SLACK_WEBHOOK_URL=
# Optional: Twilio for SMS (leave blank to disable)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_SMS_TO=

# ---- Browser Automation ----
# Path to the browser automation sidecar script
BROWSER_SCRIPT_PATH=/Users/YOURNAME/Projects/job-scraper/scripts/browser_agent.js
# Timeout in milliseconds for a single form fill attempt
BROWSER_TIMEOUT_MS=30000

# ---- Polling ----
# How often to run the discovery poller (cron expression, n8n format)
POLL_CRON=0 */4 * * *
# Max consecutive failures before pausing a company
MAX_CONSECUTIVE_FAILURES=2
# Days before a job not seen in polls is marked closed
JOB_STALE_DAYS=14
# Hours before a needs_attention job triggers a STALE_ATTENTION alert
STALE_ATTENTION_HOURS=48
